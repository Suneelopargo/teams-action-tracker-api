generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  PARTICIPANT
}

//////////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////////

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(PARTICIPANT)
  isActive Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedActionItems ActionItem[]  @relation("AssignedUser")
  participants        Participant[]
}

//////////////////////////////////////////////////////////
// MEETING
//////////////////////////////////////////////////////////

model Meeting {
  id             Int      @id @default(autoincrement())
  graphMeetingId String?  @unique
  title          String
  meetingDate    DateTime
  source         String   @default("TEAMS")

  participants Participant[]
  transcripts  Transcript[]
  actionItems  ActionItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////////
// PARTICIPANT
//////////////////////////////////////////////////////////

model Participant {
  id Int @id @default(autoincrement())

  meetingId Int
  meeting   Meeting @relation(fields: [meetingId], references: [id])

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  name  String
  email String?

  createdAt DateTime @default(now())

  @@index([meetingId])
  @@index([userId])
  @@index([email])
}

//////////////////////////////////////////////////////////
// TRANSCRIPT
//////////////////////////////////////////////////////////

model Transcript {
  id Int @id @default(autoincrement())

  meetingId Int
  meeting   Meeting @relation(fields: [meetingId], references: [id])

  transcriptText String @db.LongText

  sourceFile String?
  sourceType String?

  createdAt DateTime @default(now())

  @@index([meetingId])
}

//////////////////////////////////////////////////////////
// ACTION ITEM
//////////////////////////////////////////////////////////

model ActionItem {
  id Int @id @default(autoincrement())

  meetingId Int
  meeting   Meeting @relation(fields: [meetingId], references: [id])

  ownerName  String?
  ownerEmail String?

  // Existing functionality
  actionText String? @db.LongText

  // New functionality
  title       String?
  description String? @db.LongText

  assignedToUserId Int?
  assignedUser     User? @relation("AssignedUser", fields: [assignedToUserId], references: [id])

  priority String?
  status   String?

  dueDate DateTime?

  reminderSent Int       @default(0)
  lastReminder DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emailLogs EmailLog[]

  @@index([meetingId])
  @@index([assignedToUserId])
  @@index([ownerEmail])
  @@index([status])
  @@index([lastReminder])
}

//////////////////////////////////////////////////////////
// EMAIL LOG
//////////////////////////////////////////////////////////

model EmailLog {
  id Int @id @default(autoincrement())

  actionItemId Int?
  actionItem   ActionItem? @relation(fields: [actionItemId], references: [id])

  emailTo String
  subject String
  status  String

  sentAt DateTime?

  createdAt DateTime @default(now())

  @@index([actionItemId])
}

//////////////////////////////////////////////////////////
// APP SETTINGS
//////////////////////////////////////////////////////////

model AppSetting {
  id Int @id @default(autoincrement())

  autoSendEmails Boolean @default(true)

  reminderEnabled Boolean @default(true)

  openAiModel String @default("gpt-4o")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
